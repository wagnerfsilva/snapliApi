# Server Configuration
PORT=3000
NODE_ENV=development

# Database (Supabase PostgreSQL)
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-supabase-password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# S3 Buckets
S3_BUCKET_ORIGINAL=snapli-originals
S3_BUCKET_WATERMARKED=snapli-watermarked

# AWS Rekognition
REKOGNITION_COLLECTION_ID=snapli-faces
REKOGNITION_SIMILARITY_THRESHOLD=80

# URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# Watermark Configuration
WATERMARK_TEXT=SNAPLI
WATERMARK_OPACITY=0.3

# Upload Limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_UPLOAD=50

# Payment (Future)
ASAAS_API_KEY=your-asaas-api-key
ASAAS_ENVIRONMENT=sandbox

# SMTP (Hostinger) - usar porta 587 (STARTTLS) em cloud providers como Railway
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=suporte@snapli.com.br
SMTP_PASS=your-email-password
SMTP_FROM=Snapli <noreply@snapli.com.br>
