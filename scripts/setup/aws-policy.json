{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:HeadObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::snapli-original-photos",
        "arn:aws:s3:::snapli-original-photos/*",
        "arn:aws:s3:::snapli-watermarked-photos",
        "arn:aws:s3:::snapli-watermarked-photos/*"
      ]
    },
    {
      "Effect": "Allow",
      "Action": ["rekognition:*"],
      "Resource": "*"
    }
  ]
}
